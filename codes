#define FILTER_BY_SERVICE_UUID  true

class MyScanCallbacks : public NimBLEScanCallbacks {

    void parsePayload(const uint8_t *payload, size_t length) {
        Serial.println("\n----- AD Structures -----");
        size_t index = 0;
        int count = 1;

        while (index < length) {
            uint8_t fieldLength = payload[index];
            if (fieldLength == 0) break;
            if (index + fieldLength >= length) break;

            uint8_t type = payload[index + 1];

            Serial.println("-------------------------");
            Serial.print("Structure : ");
            Serial.println(count++);
            Serial.print("Length    : ");
            Serial.println(fieldLength);
            Serial.print("Type      : 0x");
            if (type < 16) Serial.print("0");
            Serial.println(type, HEX);
            Serial.print("Meaning   : ");

            switch (type) {
                case 0x01:
                    Serial.println("Flags");
                    break;
                case 0x08:
                    Serial.println("Shortened Local Name");
                    break;
                case 0x09:
                    Serial.println("Complete Local Name");
                    break;

                case 0x16:
                    Serial.println("Service Data");
                    
                    // --- DECODE EDDYSTONE-UID (Frame Type 0x00) ---
                    if (fieldLength >= 4 && payload[index + 2] == 0xAA && payload[index + 3] == 0xFE) {
                        uint8_t frameType = payload[index + 4];
                        
                        if (frameType == 0x00) {
                            Serial.println("      [DECODED EDDYSTONE-UID]");
                            int8_t txPower = (int8_t)payload[index + 5];
                            
                            // Extract 10-byte Namespace ID
                            char namespaceID[21];
                            char* pNamespace = namespaceID;
                            for (int i = 0; i < 10; i++) {
                                sprintf(pNamespace, "%02X", payload[index + 6 + i]);
                                pNamespace += 2;
                            }
                            
                            // Extract 6-byte Instance ID
                            char instanceID[13];
                            char* pInstance = instanceID;
                            for (int i = 0; i < 6; i++) {
                                sprintf(pInstance, "%02X", payload[index + 16 + i]);
                                pInstance += 2;
                            }
                            
                            Serial.print("         Namespace ID: ");
                            Serial.println(namespaceID);
                            Serial.print("         Instance ID : ");
                            Serial.println(instanceID);
                            Serial.print("         TX Power    : ");
                            Serial.print(txPower);
                            Serial.println(" dBm");
                        }
                    }
                    break;

                default:
                    Serial.println("Unknown");
                    break;
            }

            Serial.print("Data      : ");
            for (int i = 0; i < fieldLength - 1; i++) {
                uint8_t value = payload[index + 2 + i];
                if (type == 0x08 || type == 0x09) {
                    Serial.print((char)value);
                } else {
                    if (value < 16) Serial.print("0");
                    Serial.print(value, HEX);
                    Serial.print(" ");
                }
            }
            Serial.println();
            index += fieldLength + 1;
        }
        Serial.println("-------------------------");
    }

public:
    void onResult(const NimBLEAdvertisedDevice *device) override {
        // --- SMART FILTER LOGIC ---
        if (FILTER_BY_SERVICE_UUID) {
            bool foundTarget = false;
            if (device->isAdvertisingService(NimBLEUUID("feaa"))) {
                foundTarget = true;
            } else {
                const std::vector<uint8_t>& payload = device->getPayload();
                size_t idx = 0;
                while (idx < payload.size()) {
                    uint8_t len = payload[idx];
                    if (len == 0 || idx + len >= payload.size()) break;
                    uint8_t type = payload[idx + 1];
                    if (type == 0x16 && len >= 4) { 
                        if (payload[idx + 2] == 0xAA && payload[idx + 3] == 0xFE) {
                            foundTarget = true;
                            break;
                        }
                    }
                    idx += len + 1;
                }
            }
            if (!foundTarget) return; 
        }

        unsigned long ms = millis();
        unsigned long elapsedSecs = ms / 1000;
        unsigned long elapsedMs = ms % 1000;


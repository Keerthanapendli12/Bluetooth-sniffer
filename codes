                        char beaconIdStr[41];
                        char* pId = beaconIdStr;
                        for (int i = 0; i < 20; i++) {
                            sprintf(pId, "%02x", payload[index + 6 + i]);
                            pId += 2;
                        }
                        
                        // Extract Calibrated RSSI (Tx Power at 1m)
                        int8_t referenceRssi = (int8_t)payload[index + 26];
                        
                        // Extract Manufacturer Reserved Byte
                        uint8_t mfgReserved = payload[index + 27];
                        
                        Serial.print("         Company ID  : 0x");
                        Serial.println(companyId, HEX);
                        Serial.print("         Beacon ID   : ");
                        Serial.println(beaconIdStr);
                        Serial.print("         Ref RSSI    : ");
                        Serial.print(referenceRssi);
                        Serial.println(" dBm");
                        Serial.print("         Mfg Reserved: 0x");
                        Serial.println(mfgReserved, HEX);
                    }
                    break;

                default:
                    Serial.println("Unknown");
                    break;
            }

            Serial.print("Data      : ");
            for (int i = 0; i < fieldLength - 1; i++) {
                uint8_t value = payload[index + 2 + i];
                if (type == 0x08 || type == 0x09) {
                    Serial.print((char)value);
                } else {
                    if (value < 16) Serial.print("0");
                    Serial.print(value, HEX);
                    Serial.print(" ");
                }
            }
            Serial.println();
            index += fieldLength + 1;
        }
        Serial.println("-------------------------");
    }

public:
    void onResult(const NimBLEAdvertisedDevice *device) override {
        unsigned long ms = millis();
        unsigned long elapsedSecs = ms / 1000;
        unsigned long elapsedMs = ms % 1000;

        unsigned long totalSecs = startSec + elapsedSecs;
        unsigned long totalMins = startMin + (totalSecs / 60);
        unsigned long totalHours = startHour + (totalMins / 60);

        char timeBuffer[16];
        sprintf(timeBuffer, "%02d:%02d:%02d.%03lu", (int)(totalHours % 24), (int)(totalMins % 60), (int)(totalSecs % 60), elapsedMs);

        Serial.println("\n========================================");
        Serial.print("Discovery Time (IST): ");
        Serial.println(timeBuffer);
        Serial.print("MAC Address         : ");
        Serial.println(device->getAddress().toString().c_str());
        Serial.print("RSSI                : ");
        Serial.print(device->getRSSI());
        Serial.println(" dBm");

        if (device->haveName()) {
            Serial.print("Device Name         : ");
            Serial.println(device->getName().c_str());
        } else {
            Serial.println("Device Name         : Not Available");
        }

        const std::vector<uint8_t> &payload = device->getPayload();
        Serial.print("Payload Size        : ");
        Serial.print(payload.size());
        Serial.println(" Bytes");

        Serial.print("\nRaw Payload         : ");
        for (size_t i = 0; i < payload.size(); i++) {
            if (payload[i] < 16) Serial.print("0");
            Serial.print(payload[i], HEX);
            Serial.print(" ");
        }
        Serial.println();

        parsePayload(payload.data(), payload.size());
        Serial.println("========================================");
    }
};

NimBLEScan *pScan;

void setup() {
    Serial.begin(115200);
    Serial.println("\nStarting BLE Scanner...\n");
    parseCompileTime();
    
    NimBLEDevice::init("");
    pScan = NimBLEDevice::getScan();
    pScan->setScanCallbacks(new MyScanCallbacks(), false);
    pScan->setActiveScan(false);
    pScan->setInterval(100);
    pScan->setWindow(100);
    
    pScan->start(0, false); 
}

void loop() {
    delay(1000);
}

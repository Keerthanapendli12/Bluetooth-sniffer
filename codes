// --- PART 2: EDDYSTONE SPEC CONSTANTS ---
static const char* urlSchemes[] = {
    "http://www.",
    "https://www.",
    "http://",
    "https://"
};

static const char* urlExpansions[] = {
    ".com/", ".org/", ".edu/", ".net/", ".info/", ".biz/", ".gov/",
    ".com", ".org", ".edu", ".net", ".info", ".biz", ".gov"
};

class MyScanCallbacks : public NimBLEScanCallbacks {

    void parsePayload(const uint8_t *payload, size_t length) {
        Serial.println("\n----- AD Structures -----");
        size_t index = 0;
        int count = 1;

        while (index < length) {
            uint8_t fieldLength = payload[index];
            if (fieldLength == 0) break;
            if (index + fieldLength >= length) break;

            uint8_t type = payload[index + 1];

            Serial.println("-------------------------");
            Serial.print("Structure : ");
            Serial.println(count++);
            Serial.print("Length    : ");
            Serial.println(fieldLength);
            Serial.print("Type      : 0x");
            if (type < 16) Serial.print("0");
            Serial.println(type, HEX);
            Serial.print("Meaning   : ");

            switch (type) {
                case 0x01:
                    Serial.println("Flags");
                    break;
                case 0x08:
                    Serial.println("Shortened Local Name");
                    break;
                case 0x09:
                    Serial.println("Complete Local Name");
                    break;

                case 0x16:
                    Serial.println("Service Data");
                    
                    // --- PART 2: DECODE EDDYSTONE-URL ---
                    // Eddystone-URL signature has:
                    // 1. Min length of 6 bytes inside payload data
                    // 2. Service UUID = 0xFEAA -> little-endian bytes: 0xAA, 0xFE
                    // 3. Eddystone Frame Type = 0x10 (URL frame)
                    if (fieldLength >= 6 && 
                        payload[index + 2] == 0xAA && payload[index + 3] == 0xFE && 
                        payload[index + 4] == 0x10) {
                        
                        Serial.println("      [DECODED EDDYSTONE-URL]");
                        
                        uint8_t txPower = payload[index + 5];   // Calibrated Tx Power at 0m
                        uint8_t schemeCode = payload[index + 6]; // URL Prefix (e.g. 0x01 for https://www.)
                        
                        String url = "";
                        
                        // Add URL Scheme prefix
                        if (schemeCode < 4) {
                            url += urlSchemes[schemeCode];
                        }
                        
                        // Decode URL characters and expansions
                        for (size_t i = 7; i <= fieldLength; i++) {
                            uint8_t b = payload[index + i];
                            if (b <= 0x0D) {
                                url += urlExpansions[b]; // e.g. 0x07 replaces with ".com"
                            } else if (b >= 32 && b <= 126) {
                                url += (char)b;          // Printable ASCII characters
                            } else {
                                // Non-printable hex
                                url += "\\x";
                                if (b < 16) url += "0";
                                url += String(b, HEX);
                            }
                        }
                        
                        Serial.print("         URL  : ");
                        Serial.println(url);
                        Serial.print("         TX Pwr: ");
                        Serial.print((int8_t)txPower);
                        Serial.println(" dBm");
                    }
                    break;

                case 0xFF:
                    Serial.println("Manufacturer Specific Data");
                    
                    // --- PART 1: DECODE iBEACON ---
                    if (fieldLength - 1 >= 25 && 
                        payload[index + 2] == 0x4C && payload[index + 3] == 0x00 && 
                        payload[index + 4] == 0x02 && payload[index + 5] == 0x15) {
                        
                        Serial.println("      [DECODED iBEACON]");
                        
                        char uuidStr[37];
                        sprintf(uuidStr, "%02x%02x%02x%02x-%02x%02x-%02x%02x-%02x%02x-%02x%02x%02x%02x%02x%02x",
                                payload[index + 6], payload[index + 7], payload[index + 8], payload[index + 9],
                                payload[index + 10], payload[index + 11],
                                payload[index + 12], payload[index + 13],
                                payload[index + 14], payload[index + 15],
                                payload[index + 16], payload[index + 17], 
                                payload[index + 18], payload[index + 19], 
                                payload[index + 20], payload[index + 21]);
                        
                        uint16_t major = (payload[index + 22] << 8) | payload[index + 23];
                        uint16_t minor = (payload[index + 24] << 8) | payload[index + 25];
                        int8_t txPower = (int8_t)payload[index + 26];
                        
                        Serial.print("         UUID : ");
                        Serial.println(uuidStr);
                        Serial.print("         Major: ");
                        Serial.println(major);
                        Serial.print("         Minor: ");
                        Serial.println(minor);
                        Serial.print("         TX Pwr: ");
                        Serial.print(txPower);
                        Serial.println(" dBm");
                    }
                    break;

                default:
                    Serial.println("Unknown");
                    break;
            }

            Serial.print("Data      : ");
            for (int i = 0; i < fieldLength - 1; i++) {
                uint8_t value = payload[index + 2 + i];
                if (type == 0x08 || type == 0x09) {
                    Serial.print((char)value);
                } else {
